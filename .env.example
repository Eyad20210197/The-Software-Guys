# ==============================================================================
# The Software Guys - SaaS Platform Configuration Environment Variables Template
# ==============================================================================

# Node Environment [development | production]
NODE_ENV=development

# 1. DATABASE CONFIGURATION (Neon Serverless PostgreSQL)
# Synced via Prisma client ORM
DATABASE_URL="postgresql://username:password@ep-cool-snowflake-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# 2. BACKEND API SERVICE PORT & CORS SETTINGS
PORT=3001
FRONTEND_URL="http://localhost:3000"

# 3. NEXTAUTH SECURITY & JWT SECRET KEYS
# Required by NextAuth on next.js frontend apps
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-long-next-auth-jwt-random-salt-string"

# Admin default user setup (used by backend seeder in monorepo integration)
DEFAULT_ADMIN_EMAIL="admin@thesoftwareguys.com"
DEFAULT_ADMIN_PASSWORD="secure-super-brutal-admin-pass-2026"
DEFAULT_ADMIN_NAME="The Software Guys Admin"
